{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Session Manager",
  "version": "0.1.0",
  "identifier": "local.session-manager.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Session Manager",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNTMyQTQ5M0FERjAyRDUKUldUVkF0ODZTU3BUNnJZY1R4T2hQanNHU1lmQjhzaGI2RGNKdk9KajlURjBIMC9NNmNQL1Z4UGcK",
      "endpoints": [
        "https://github.com/CatheadOwl/session-manager/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
